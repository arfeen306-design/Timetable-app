# ─────────────────────────────────────────────────────────
#  Timetable SaaS — Production Environment Variables
#  Copy this to .env (never commit your real .env to git!)
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection String (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_HEX_32

# ── Mode ──────────────────────────────────────────────────
# Must be false in production (hides /docs, shows safe errors)
DEBUG=false

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# e.g. your Vercel/Netlify deployment URL
ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
